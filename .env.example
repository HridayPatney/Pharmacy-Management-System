# Copy this file to `.env` and fill in real values. Never commit `.env`.

# Required for JWT auth (long random string)
JWT_SECRET=

# Optional token lifetime in minutes (default 60)
# JWT_EXPIRE_MINUTES=60

# Create first admin on startup when users table is empty
BOOTSTRAP_ADMIN_EMAIL=
BOOTSTRAP_ADMIN_PASSWORD=

# Required for POST /ocr/extract (Google AI Studio / Gemini API key)
GEMINI_API_KEY=
# Optional OCR model (default: gemini-3-flash-preview)
# GEMINI_OCR_MODEL=gemini-3-flash-preview

# Comma-separated browser origins allowed to call the API.
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:8501,http://127.0.0.1:8501

# Local default: SQLite under repo. Production (Render Postgres): paste the URL from Render.
# DATABASE_URL=postgresql://user:pass@host/dbname

# Optional: Chroma persistence directory (default: <repo>/chroma_store)
# On Render, mount a disk and set e.g. CHROMA_PATH=/data/chroma_store
# CHROMA_PATH=

# Optional: Chroma collection name (default: medicine_embeddings)
# CHROMA_COLLECTION=medicine_embeddings

# Optional: sentence-transformers model (default: all-MiniLM-L6-v2)
# EMBEDDING_MODEL=all-MiniLM-L6-v2

# Include Gemini key presence in GET /health/ready (default false)
# HEALTH_CHECK_GEMINI=false

# Prescription storage: local (default) or s3
STORAGE_BACKEND=local
# UPLOAD_DIR=   # optional override; default <repo>/uploads

# S3 (when STORAGE_BACKEND=s3)
# S3_BUCKET=
# S3_REGION=ap-south-1
# S3_ENDPOINT_URL=   # optional (MinIO / R2)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
