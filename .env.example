# Copy this file to `.env` and fill in real values. Never commit `.env`.

# Required for POST /ocr/extract (Google AI Studio / Gemini API key)
GEMINI_API_KEY=

# Comma-separated browser origins allowed to call the API.
# Default if unset: http://localhost:8501 (Streamlit)
# Local React later might use: http://localhost:5173,http://localhost:3000
CORS_ORIGINS=http://localhost:8501

# Optional: override default SQLite at <repo>/pharma.db
# DATABASE_URL=sqlite:///C:/path/to/pharma.db

# Optional: Chroma persistence directory (default: <repo>/chroma_store)
# CHROMA_PATH=

# Optional: Chroma collection name (default: medicine_embeddings)
# CHROMA_COLLECTION=medicine_embeddings

# Optional: sentence-transformers model (default: all-MiniLM-L6-v2)
# EMBEDDING_MODEL=all-MiniLM-L6-v2
